rules_version = '2';

// Rapor Yazma Programı — Firestore Güvenlik Kuralları (Faz 0 taslağı)
//
// İlkeler:
//  1) Varsayılan: HER ŞEY KAPALI. Yalnızca aşağıda açıkça izin verilen yol açık.
//  2) Kullanıcı yalnızca KENDİ raporlarını okur/yazar/siler (users/{uid}/reports).
//  3) Her yazmada zarf alanları doğrulanır; expireAt (30 gün TTL) zorunludur ve
//     istemci kurcalamasıyla süresiz uzatılamaz (üst sınır: şimdi + 40 gün).
//
// Not: Belge boyutu limitini (1 MiB) Firestore kendisi uygular; ham belge
// metinleri (sourceValues) istemci beyaz listesi gereği zaten pakete girmez.

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function isValidReportEnvelope() {
      return request.resource.data.schema == "rapor-yazma-cloud"
        && request.resource.data.schemaVersion is int
        && request.resource.data.schemaVersion >= 1
        && request.resource.data.status in ["draft", "completed"]
        && request.resource.data.rev is int
        && request.resource.data.rev >= 1
        && request.resource.data.payload is map;
    }

    function hasBoundedExpiry() {
      return request.resource.data.expireAt is timestamp
        && request.resource.data.expireAt > request.time
        && request.resource.data.expireAt < request.time + duration.value(40, 'd');
    }

    match /users/{uid}/reports/{reportId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidReportEnvelope() && hasBoundedExpiry();
      allow update: if isOwner(uid) && isValidReportEnvelope() && hasBoundedExpiry();
      allow delete: if isOwner(uid);
    }

    // Varsayılan ret: yukarıda eşleşmeyen her yol kapalıdır.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
